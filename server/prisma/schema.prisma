generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  name      String
  avatar    String?
  provider  String   @default("kakao") // kakao | naver | email
  providerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  SessionMember[]
  createdSessions Session[] @relation("SessionCreator")

  @@unique([provider, providerId])
}

model Session {
  id           String   @id @default(uuid())
  name         String
  status       String   @default("active") // active | ended
  maxOperators Int      @default(2)
  createdBy    String
  creator      User     @relation("SessionCreator", fields: [createdBy], references: [id])
  createdAt    DateTime @default(now())
  endedAt      DateTime?

  members      SessionMember[]
  captions     CaptionLog[]
}

model SessionMember {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("standby") // operator | standby
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  @@unique([sessionId, userId])
}

model CaptionLog {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  userId    String
  text      String
  createdAt DateTime @default(now())
}
